<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.Fanggaozhiai.mapper.OrderItemMapper">

    <insert id="add">
        insert into order_item(ord_id,pro_id,num,total,per_money) values
        <foreach collection="orderItems" item="orderItem" separator=",">
            (#{orderItem.ordId},#{orderItem.proId},#{orderItem.num},#{orderItem.total},#{orderItem.perMoney})
        </foreach>
    </insert>
</mapper>