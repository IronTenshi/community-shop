<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.Fanggaozhiai.mapper.ShopMapper">

    <!--
        动态更新商铺信息
        根据传入的 ShopPut 对象中非空字段，选择性更新商铺名称、联系人、联系电话
        WHERE 条件：根据 id 定位要修改的商铺
    -->
    <update id="update">
        UPDATE merchant
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="person != null">
                person = #{person},
            </if>
            <if test="phone != null">
                phone = #{phone},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!--
        分页模糊查询商铺列表
        支持按商铺名称进行模糊匹配
        与 PageHelper 分页插件配合使用，实现物理分页
    -->
    <select id="list" resultType="com.Fanggaozhiai.entity.Merchant">
        SELECT * FROM  merchant
        <where>
            <if test="name != null">
                name LIKE concat('%',#{name},'%')
            </if>
        </where>
    </select>
</mapper>