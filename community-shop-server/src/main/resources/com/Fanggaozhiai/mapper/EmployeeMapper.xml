<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.Fanggaozhiai.mapper.EmployeeMapper">

    <!--
        动态更新员工信息
        根据传入的 EmployeePut 对象中非空字段，选择性更新员工姓名、账号、密码
        WHERE 条件：根据 id 定位要修改的员工
    -->
    <update id="update">
        UPDATE employee
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="username != null">
                username = #{username},
            </if>
            <if test="password != null">
                password = #{password},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!--
        分页模糊查询员工列表
        支持按员工姓名进行模糊匹配，按入职时间降序排列（新员工在前）
        与 PageHelper 分页插件配合使用，实现物理分页
    -->
    <select id="list" resultType="com.Fanggaozhiai.entity.Employee">
        SELECT * FROM employee
        <where>
            <if test="name != null">
                name LIKE concat('%',#{name},'%')
            </if>
        </where>
        order by entry_time desc
    </select>
</mapper>