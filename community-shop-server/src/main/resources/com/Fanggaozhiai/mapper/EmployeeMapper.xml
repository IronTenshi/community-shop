<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.Fanggaozhiai.mapper.EmployeeMapper">
    <update id="update">
        UPDATE employee
        <set>
            <if test="name != null">
                name = #{name},
            </if>
            <if test="username != null">
                username = #{username},
            </if>
            <if test="password != null">
                password = #{password},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <select id="list" resultType="com.Fanggaozhiai.entity.Employee">
        SELECT * FROM employee
        <where>
            <if test="name != null">
                name LIKE concat('%',#{name},'%')
            </if>
        </where>
        order by entry_time
    </select>
</mapper>